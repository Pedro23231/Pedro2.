local UILibrary = {}
local TS = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")

local function createTween(obj, props, time, style)
    style = style or Enum.EasingStyle.Quad
    return TS:Create(obj, TweenInfo.new(time, style, Enum.EasingDirection.Out), props)
end

function UILibrary:Create(title)
    local player = game.Players.LocalPlayer
    local gui = Instance.new("ScreenGui")
    gui.Name = "UILibWindow"
    gui.ResetOnSpawn = false
    gui.Parent = player:WaitForChild("PlayerGui")

    local window = Instance.new("Frame")
    window.Name = "MainWindow"
    window.Size = UDim2.new(0, 420, 0, 320)
    window.Position = UDim2.new(0.5, -210, 0.5, -160)
    window.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
    window.BorderSizePixel = 0
    window.ZIndex = 10
    window.Parent = gui
    Instance.new("UICorner", window).CornerRadius = UDim.new(0, 10)
    Instance.new("UIStroke", window).ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- Title Bar
    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1, 0, 0, 45)
    titleBar.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    titleBar.Parent = window
    Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0, 10)

    local titleText = Instance.new("TextLabel")
    titleText.Size = UDim2.new(1, -100, 1, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = title or "Grok UI Library"
    titleText.TextColor3 = Color3.fromRGB(240, 240, 240)
    titleText.TextXAlignment = Enum.TextXAlignment.Left
    titleText.Font = Enum.Font.GothamBold
    titleText.TextSize = 16
    titleText.Parent = titleBar

    local minBtn = Instance.new("TextButton")
    minBtn.Size = UDim2.new(0, 35, 0, 35)
    minBtn.Position = UDim2.new(1, -80, 0.5, -17.5)
    minBtn.BackgroundColor3 = Color3.fromRGB(255, 193, 7)
    minBtn.Text = "−"
    minBtn.TextColor3 = Color3.new(0,0,0)
    minBtn.Font = Enum.Font.GothamBold
    minBtn.Parent = titleBar
    Instance.new("UICorner", minBtn).CornerRadius = UDim.new(1, 0)

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 35, 0, 35)
    closeBtn.Position = UDim2.new(1, -40, 0.5, -17.5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(220, 53, 69)
    closeBtn.Text = "×"
    closeBtn.TextColor3 = Color3.new(1,1,1)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.Parent = titleBar
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(1, 0)

    -- Scrolling Content
    local contentFrame = Instance.new("ScrollingFrame")
    contentFrame.Size = UDim2.new(1, -20, 1, -65)
    contentFrame.Position = UDim2.new(0, 10, 0, 55)
    contentFrame.BackgroundTransparency = 1
    contentFrame.ScrollBarThickness = 5
    contentFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    contentFrame.Parent = window
    local layout = Instance.new("UIListLayout", contentFrame)
    layout.Padding = UDim.new(0, 10)
    layout.SortOrder = Enum.SortOrder.LayoutOrder

    -- Draggable Logic (full implementation)
    local isDragging = false
    local dragStartPos, startFramePos
    titleBar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            dragStartPos = inp.Position
            startFramePos = window.Position
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if isDragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
            local delta = inp.Position - dragStartPos
            window.Position = UDim2.new(startFramePos.X.Scale, startFramePos.X.Offset + delta.X, startFramePos.Y.Scale, startFramePos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)

    -- Minimize Logic
    local isMinimized = false
    local originalSize = window.Size
    minBtn.MouseButton1Click:Connect(function()
        isMinimized = not isMinimized
        if isMinimized then
            createTween(window, {Size = UDim2.new(0, 420, 0, 55)}, 0.25):Play()
            contentFrame.Visible = false
        else
            createTween(window, {Size = originalSize}, 0.25):Play()
            contentFrame.Visible = true
        end
    end)

    closeBtn.MouseButton1Click:Connect(function()
        gui:Destroy()
    end)

    local windowAPI = {Content = contentFrame, Gui = gui}

    -- Button
    function windowAPI:AddButton(name, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 45)
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        btn.Text = name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.GothamSemibold
        btn.TextSize = 15
        btn.Parent = contentFrame
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
        local stroke = Instance.new("UIStroke", btn)
        stroke.Transparency = 0.7

        btn.MouseButton1Click:Connect(function()
            createTween(btn, {BackgroundColor3 = Color3.fromRGB(70, 70, 70)}, 0.1):Play()
            task.delay(0.1, function()
                createTween(btn, {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}, 0.1):Play()
            end)
            if callback then callback() end
        end)
        return btn
    end

    -- Toggle
    function windowAPI:AddToggle(name, defaultState, callback)
        local container = Instance.new("Frame")
        container.Size = UDim2.new(1, -10, 0, 45)
        container.BackgroundTransparency = 1
        container.Parent = contentFrame

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.65, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = name
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextColor3 = Color3.fromRGB(255,255,255)
        label.Parent = container

        local switch = Instance.new("TextButton")
        switch.Size = UDim2.new(0, 55, 0, 28)
        switch.Position = UDim2.new(1, -65, 0.5, -14)
        switch.BackgroundColor3 = defaultState and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(80, 80, 80)
        switch.Text = ""
        switch.Parent = container
        Instance.new("UICorner", switch).CornerRadius = UDim.new(1, 0)

        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 24, 0, 24)
        knob.Position = defaultState and UDim2.new(1, -28, 0.5, -12) or UDim2.new(0, 2, 0.5, -12)
        knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
        knob.Parent = switch
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

        local state = defaultState or false
        switch.MouseButton1Click:Connect(function()
            state = not state
            createTween(switch, {BackgroundColor3 = state and Color3.fromRGB(0,200,100) or Color3.fromRGB(80,80,80)}, 0.25):Play()
            createTween(knob, {Position = state and UDim2.new(1, -28, 0.5, -12) or UDim2.new(0, 2, 0.5, -12)}, 0.25):Play()
            if callback then callback(state) end
        end)
        return {Set = function(newState) state = newState; /* update tweens */ end}
    end

    -- Slider (full precision + real-time)
    function windowAPI:AddSlider(name, minVal, maxVal, defaultVal, callback)
        local container = Instance.new("Frame")
        container.Size = UDim2.new(1, -10, 0, 70)
        container.BackgroundTransparency = 1
        container.Parent = contentFrame

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 0, 20)
        label.BackgroundTransparency = 1
        label.Text = string.format("%s: %.1f", name, defaultVal)
        label.TextColor3 = Color3.fromRGB(255,255,255)
        label.Parent = container

        local track = Instance.new("Frame")
        track.Size = UDim2.new(1, 0, 0, 12)
        track.Position = UDim2.new(0, 0, 0, 35)
        track.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
        track.Parent = container
        Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
        fill.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
        fill.Parent = track
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

        local draggingSlider = false
        track.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingSlider = true
            end
        end)
        UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
        end)
        RS.RenderStepped:Connect(function()
            if draggingSlider then
                local relX = math.clamp((UIS:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                local value = minVal + relX * (maxVal - minVal)
                value = math.floor(value * 10) / 10
                fill.Size = UDim2.new(relX, 0, 1, 0)
                label.Text = string.format("%s: %.1f", name, value)
                if callback then callback(value) end
            end
        end)
    end

    -- Dropdown
    function windowAPI:AddDropdown(name, optionList, callback)
        local container = Instance.new("Frame")
        container.Size = UDim2.new(1, -10, 0, 45)
        container.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        container.Parent = contentFrame
        Instance.new("UICorner", container).CornerRadius = UDim.new(0, 8)

        local display = Instance.new("TextLabel")
        display.Size = UDim2.new(1, -40, 1, 0)
        display.BackgroundTransparency = 1
        display.Text = name .. ": " .. optionList[1]
        display.TextXAlignment = Enum.TextXAlignment.Left
        display.Parent = container

        local arrow = Instance.new("TextLabel")
        arrow.Size = UDim2.new(0, 30, 1, 0)
        arrow.Position = UDim2.new(1, -35, 0, 0)
        arrow.BackgroundTransparency = 1
        arrow.Text = "▼"
        arrow.Parent = container

        local dropdownList = Instance.new("Frame")
        dropdownList.Visible = false
        dropdownList.Size = UDim2.new(1, 0, 0, #optionList * 35)
        dropdownList.Position = UDim2.new(0, 0, 1, 5)
        dropdownList.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        dropdownList.ZIndex = 20
        dropdownList.Parent = container
        Instance.new("UICorner", dropdownList).CornerRadius = UDim.new(0, 8)

        local listLayout2 = Instance.new("UIListLayout", dropdownList)
        listLayout2.SortOrder = Enum.SortOrder.LayoutOrder

        for i, opt in ipairs(optionList) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(1, 0, 0, 35)
            optBtn.BackgroundTransparency = 1
            optBtn.Text = opt
            optBtn.Parent = dropdownList
            optBtn.MouseButton1Click:Connect(function()
                display.Text = name .. ": " .. opt
                dropdownList.Visible = false
                if callback then callback(opt, i) end
            end)
        end

        container.MouseButton1Click:Connect(function()
            dropdownList.Visible = not dropdownList.Visible
        end)
    end

    -- Input
    function windowAPI:AddInput(placeholder, default, callback)
        local tb = Instance.new("TextBox")
        tb.Size = UDim2.new(1, -10, 0, 45)
        tb.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        tb.PlaceholderText = placeholder
        tb.Text = default or ""
        tb.TextColor3 = Color3.fromRGB(255,255,255)
        tb.ClearTextOnFocus = false
        tb.Parent = contentFrame
        Instance.new("UICorner", tb).CornerRadius = UDim.new(0, 8)
        tb.FocusLost:Connect(function(enterPressed)
            if callback then callback(tb.Text) end
        end)
    end

    contentFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        contentFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end)

    return windowAPI
end

--// UILibrary Full Self-Contained - Fixed & Enhanced
local UILibrary = {}
local TS = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")

local function createTween(obj, props, time)
    return TS:Create(obj, TweenInfo.new(time or 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
end

function UILibrary:Create(title)
    local player = game.Players.LocalPlayer
    local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
    gui.ResetOnSpawn = false

    local window = Instance.new("Frame")
    window.Size = UDim2.new(0, 420, 0, 340)
    window.Position = UDim2.new(0.5, -210, 0.4, 0)
    window.BackgroundColor3 = Color3.fromRGB(25, 25, 28)
    window.Parent = gui
    Instance.new("UICorner", window).CornerRadius = UDim.new(0, 12)
    Instance.new("UIStroke", window){Color = Color3.fromRGB(60,60,70), Thickness = 1.5}

    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1,0,0,48)
    titleBar.BackgroundColor3 = Color3.fromRGB(18,18,22)
    titleBar.Parent = window
    Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0,12)

    local titleLbl = Instance.new("TextLabel", titleBar)
    titleLbl.Size = UDim2.new(1,-110,1,0)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title or "UI Library - Grok Enhanced"
    titleLbl.TextColor3 = Color3.fromRGB(240,240,245)
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 17

    local minBtn = Instance.new("TextButton", titleBar)
    minBtn.Size = UDim2.new(0,36,0,36); minBtn.Position = UDim2.new(1,-82,0,6)
    minBtn.BackgroundColor3 = Color3.fromRGB(255,180,0)
    minBtn.Text = "−"; minBtn.TextColor3 = Color3.new(0,0,0)

    local closeBtn = Instance.new("TextButton", titleBar)
    closeBtn.Size = UDim2.new(0,36,0,36); closeBtn.Position = UDim2.new(1,-40,0,6)
    closeBtn.BackgroundColor3 = Color3.fromRGB(230,60,70)
    closeBtn.Text = "×"; closeBtn.TextColor3 = Color3.new(1,1,1)

    local scroll = Instance.new("ScrollingFrame", window)
    scroll.Size = UDim2.new(1,-20,1,-70)
    scroll.Position = UDim2.new(0,10,0,58)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 6
    scroll.CanvasSize = UDim2.new(0,0,0,0)
    local uiList = Instance.new("UIListLayout", scroll)
    uiList.Padding = UDim.new(0,12)
    uiList.SortOrder = Enum.SortOrder.LayoutOrder

    -- Draggable full
    local dragging = false
    titleBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
        window.Position += UDim2.new(0, i.Delta.X, 0, i.Delta.Y)
    end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    -- Minimize
    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        createTween(window, {Size = minimized and UDim2.new(0,420,0,55) or UDim2.new(0,420,0,340)}):Play()
        scroll.Visible = not minimized
    end)
    closeBtn.MouseButton1Click:Connect(function() gui:Destroy() end)

    local api = {Scroll = scroll}

    function api:AddButton(txt, cb)
        local b = Instance.new("TextButton", scroll)
        b.Size = UDim2.new(1,-10,0,48)
        b.BackgroundColor3 = Color3.fromRGB(45,45,52)
        b.Text = txt
        b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,10)
        b.MouseButton1Click:Connect(cb or function() end)
    end

    function api:AddToggle(txt, def, cb)
        local f = Instance.new("Frame", scroll); f.Size = UDim2.new(1,-10,0,48); f.BackgroundTransparency = 1
        local l = Instance.new("TextLabel", f); l.Size = UDim2.new(0.7,0,1,0); l.BackgroundTransparency=1; l.Text = txt; l.TextXAlignment = Enum.TextXAlignment.Left
        local tog = Instance.new("TextButton", f); tog.Size = UDim2.new(0,58,0,30); tog.Position = UDim2.new(1,-70,0.5,-15); tog.BackgroundColor3 = def and Color3.fromRGB(40,200,90) or Color3.fromRGB(90,90,95)
        Instance.new("UICorner", tog).CornerRadius = UDim.new(1,0)
        local knob = Instance.new("Frame", tog); knob.Size = UDim2.new(0,26,0,26); knob.Position = def and UDim2.new(1,-30,0.5,-13) or UDim2.new(0,2,0.5,-13)
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
        local s = def
        tog.MouseButton1Click:Connect(function()
            s = not s
            createTween(tog, {BackgroundColor3 = s and Color3.fromRGB(40,200,90) or Color3.fromRGB(90,90,95)}):Play()
            createTween(knob, {Position = s and UDim2.new(1,-30,0.5,-13) or UDim2.new(0,2,0.5,-13)}):Play()
            if cb then cb(s) end
        end)
    end

    function api:AddSlider(txt, minv, maxv, defv, cb)
        local f = Instance.new("Frame", scroll); f.Size = UDim2.new(1,-10,0,72); f.BackgroundTransparency = 1
        local lbl = Instance.new("TextLabel", f); lbl.Size = UDim2.new(1,0,0,22); lbl.BackgroundTransparency=1; lbl.Text = txt..": "..defv
        local track = Instance.new("Frame", f); track.Size = UDim2.new(1,-4,0,14); track.Position = UDim2.new(0,2,0,35); track.BackgroundColor3 = Color3.fromRGB(50,50,55)
        Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
        local fill = Instance.new("Frame", track); fill.Size = UDim2.new((defv-minv)/(maxv-minv),0,1,0); fill.BackgroundColor3 = Color3.fromRGB(0,160,255)
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
        local drag = false
        track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
        UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
        RS.RenderStepped:Connect(function()
            if drag then
                local x = math.clamp((UIS:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                local val = math.floor((minv + x * (maxv - minv)) * 10) / 10
                fill.Size = UDim2.new(x,0,1,0)
                lbl.Text = txt..": "..val
                if cb then cb(val) end
            end
        end)
    end

    function api:AddDropdown(txt, opts, cb)
        local f = Instance.new("Frame", scroll); f.Size = UDim2.new(1,-10,0,48); f.BackgroundColor3 = Color3.fromRGB(45,45,52)
        Instance.new("UICorner", f).CornerRadius = UDim.new(0,10)
        local disp = Instance.new("TextLabel", f); disp.Size = UDim2.new(1,-40,1,0); disp.BackgroundTransparency=1; disp.Text = txt..": "..opts[1]
        local lst = Instance.new("Frame", f); lst.Visible=false; lst.Size=UDim2.new(1,0,0,#opts*36); lst.Position=UDim2.new(0,0,1,5); lst.BackgroundColor3=Color3.fromRGB(30,30,35); lst.ZIndex=100
        Instance.new("UICorner", lst).CornerRadius = UDim.new(0,8)
        for _,o in opts do
            local ob = Instance.new("TextButton", lst); ob.Size=UDim2.new(1,0,0,36); ob.BackgroundTransparency=1; ob.Text=o
            ob.MouseButton1Click:Connect(function() disp.Text=txt..": "..o; lst.Visible=false; if cb then cb(o) end end)
        end
        f.MouseButton1Click:Connect(function() lst.Visible = not lst.Visible end)
    end

    function api:AddInput(plc, def, cb)
        local tb = Instance.new("TextBox", scroll)
        tb.Size = UDim2.new(1,-10,0,48)
        tb.BackgroundColor3 = Color3.fromRGB(45,45,52)
        tb.PlaceholderText = plc
        tb.Text = def or ""
        Instance.new("UICorner", tb).CornerRadius = UDim.new(0,10)
        tb.FocusLost:Connect(function() if cb then cb(tb.Text) end end)
    end

    uiList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0,0,0, uiList.AbsoluteContentSize.Y + 30)
    end)

    return api
end
