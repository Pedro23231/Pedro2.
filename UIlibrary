            -- ── Toggle ────────────────────
            function Section:AddToggle(label, default, callback)
                local state = default or false

                local row = Instance.new("Frame")
                row.Size              = UDim2.new(1, 0, 0, 36)
                row.BackgroundColor3  = Theme.Surface
                row.BorderSizePixel   = 0
                row.LayoutOrder       = self._order()
                row.Parent            = page
                AddCorner(row)
                AddStroke(row, Theme.Border, 1)

                local lbl = Instance.new("TextLabel")
                lbl.Size              = UDim2.new(1, -60, 1, 0)
                lbl.Position          = UDim2.fromOffset(12, 0)
                lbl.BackgroundTransparency = 1
                lbl.Text              = label
                lbl.TextColor3        = Theme.Text
                lbl.TextSize          = 13
                lbl.Font              = Enum.Font.Gotham
                lbl.TextXAlignment    = Enum.TextXAlignment.Left
                lbl.Parent            = row

                -- Switch track
                local track = Instance.new("Frame")
                track.Size              = UDim2.fromOffset(38, 20)
                track.Position          = UDim2.new(1, -50, 0.5, -10)
                track.BackgroundColor3  = state and Theme.Toggle_On or Theme.Toggle_Off
                track.BorderSizePixel   = 0
                track.Parent            = row
                AddCorner(track, UDim.new(0, 10))

                -- Switch knob
                local knob = Instance.new("Frame")
                knob.Size              = UDim2.fromOffset(14, 14)
                knob.Position          = state and UDim2.fromOffset(21, 3) or UDim2.fromOffset(3, 3)
                knob.BackgroundColor3  = Color3.new(1, 1, 1)
                knob.BorderSizePixel   = 0
                knob.Parent            = track
                AddCorner(knob, UDim.new(0, 7))

                local function UpdateVisual()
                    Tween(track, {BackgroundColor3 = state and Theme.Toggle_On or Theme.Toggle_Off})
                    Tween(knob, {Position = state and UDim2.fromOffset(21, 3) or UDim2.fromOffset(3, 3)})
                end

                local btn = Instance.new("TextButton")
                btn.Size              = UDim2.fromScale(1, 1)
                btn.BackgroundTransparency = 1
                btn.Text              = ""
                btn.Parent            = row

                btn.MouseEnter:Connect(function()
                    Tween(row, {BackgroundColor3 = Theme.SurfaceHover})
                end)
                btn.MouseLeave:Connect(function()
                    Tween(row, {BackgroundColor3 = Theme.Surface})
                end)
                btn.MouseButton1Click:Connect(function()
                    state = not state
                    UpdateVisual()
                    if callback then task.spawn(callback, state) end
                end)

                UpdateVisual()

                local Toggle = {}
                function Toggle:Set(value)
                    state = value
                    UpdateVisual()
                    if callback then task.spawn(callback, state) end
                end
                function Toggle:Get() return state end
                return Toggle
            end

            -- ── Slider ────────────────────
function Section:AddSlider(label, min, max, default, callback)
                min     = min     or 0
                max     = max     or 100
                default = default or min
                local value = math.clamp(default, min, max)

                local row = Instance.new("Frame")
                row.Size              = UDim2.new(1, 0, 0, 50)
                row.BackgroundColor3  = Theme.Surface
                row.BorderSizePixel   = 0
                row.LayoutOrder       = self._order()
                row.Parent            = page
                AddCorner(row)
                AddStroke(row, Theme.Border, 1)

                local lbl = Instance.new("TextLabel")
                lbl.Size              = UDim2.new(0.7, 0, 0, 20)
                lbl.Position          = UDim2.fromOffset(12, 8)
                lbl.BackgroundTransparency = 1
                lbl.Text              = label
                lbl.TextColor3        = Theme.Text
                lbl.TextSize          = 13
                lbl.Font              = Enum.Font.Gotham
                lbl.TextXAlignment    = Enum.TextXAlignment.Left
                lbl.Parent            = row

                local valLbl = Instance.new("TextLabel")
                valLbl.Size              = UDim2.new(0.3, -12, 0, 20)
                valLbl.Position          = UDim2.new(0.7, 0, 0, 8)
                valLbl.BackgroundTransparency = 1
                valLbl.Text              = tostring(value)
                valLbl.TextColor3        = Theme.Accent
                valLbl.TextSize          = 12
                valLbl.Font              = Enum.Font.GothamBold
                valLbl.TextXAlignment    = Enum.TextXAlignment.Right
                valLbl.Parent            = row

                local track = Instance.new("Frame")
                track.Size              = UDim2.new(1, -24, 0, 4)
                track.Position          = UDim2.fromOffset(12, 34)
                track.BackgroundColor3  = Theme.Toggle_Off
                track.BorderSizePixel   = 0
                track.Parent            = row
                AddCorner(track, UDim.new(0, 2))

                local fill = Instance.new("Frame")
                fill.Size              = UDim2.fromScale((value - min) / (max - min), 1)
                fill.BackgroundColor3  = Theme.Accent
                fill.BorderSizePixel   = 0
                fill.Parent            = track
                AddCorner(fill, UDim.new(0, 2))

                local knob = Instance.new("Frame")
                knob.Size              = UDim2.fromOffset(14, 14)
                knob.Position          = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
                knob.BackgroundColor3  = Color3.new(1, 1, 1)
                knob.BorderSizePixel   = 0
                knob.ZIndex            = 2
                knob.Parent            = track
                AddCorner(knob, UDim.new(0, 7))
                AddStroke(knob, Theme.Accent, 2)

                -- FIX: usa posição absoluta do mouse, não coordenada local do botão
                local function UpdateSlider(mouseX)
                    local trackAbsX    = track.AbsolutePosition.X
                    local trackAbsSize = track.AbsoluteSize.X
                    local alpha = math.clamp((mouseX - trackAbsX) / trackAbsSize, 0, 1)
                    value = math.floor(min + alpha * (max - min) + 0.5)
                    local pct = (value - min) / (max - min)
                    fill.Size     = UDim2.fromScale(pct, 1)
                    knob.Position = UDim2.new(pct, -7, 0.5, -7)
                    valLbl.Text   = tostring(value)
                    if callback then task.spawn(callback, value) end
                end

                local sliding = false

                local hitbox = Instance.new("TextButton")
                hitbox.Size              = UDim2.new(1, 0, 1, 0)
                hitbox.BackgroundTransparency = 1
                hitbox.Text              = ""
                hitbox.ZIndex            = 3
                hitbox.Parent            = track

                -- FIX: pega X absoluto do mouse via UserInputService, não o parâmetro local
                hitbox.MouseButton1Down:Connect(function()
                    sliding = true
                    UpdateSlider(UserInputService:GetMouseLocation().X)
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                        UpdateSlider(UserInputService:GetMouseLocation().X)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)

                row.MouseEnter:Connect(function()
                    Tween(row, {BackgroundColor3 = Theme.SurfaceHover})
                end)
                row.MouseLeave:Connect(function()
                    Tween(row, {BackgroundColor3 = Theme.Surface})
                end)

                local Slider = {}
                function Slider:Set(v)
                    value = math.clamp(v, min, max)
                    local pct = (value - min) / (max - min)
                    fill.Size     = UDim2.fromScale(pct, 1)
                    knob.Position = UDim2.new(pct, -7, 0.5, -7)
                    valLbl.Text   = tostring(value)
                end
                function Slider:Get() return value end
                return Slider
            end

            -- ── Label ─────────────────────
            function Section:AddLabel(text)
                local lbl = Instance.new("TextLabel")
                lbl.Size              = UDim2.new(1, 0, 0, 28)
                lbl.BackgroundColor3  = Theme.Surface
                lbl.Text              = text
                lbl.TextColor3        = Theme.TextDim
                lbl.TextSize          = 12
                lbl.Font              = Enum.Font.Gotham
                lbl.TextXAlignment    = Enum.TextXAlignment.Left
                lbl.BorderSizePixel   = 0
                lbl.LayoutOrder       = self._order()
                lbl.Parent            = page
                AddCorner(lbl)

                local pad = Instance.new("UIPadding")
                pad.PaddingLeft = UDim.new(0, 12)
                pad.Parent      = lbl

                local Label = {}
                function Label:Set(t) lbl.Text = t end
                return Label
            end

            -- ── Keybind ───────────────────
            function Section:AddKeybind(label, default, callback)
                local key     = default or Enum.KeyCode.Unknown
                local binding = false

                local row = Instance.new("Frame")
                row.Size              = UDim2.new(1, 0, 0, 36)
                row.BackgroundColor3  = Theme.Surface
                row.BorderSizePixel   = 0
                row.LayoutOrder       = self._order()
                row.Parent            = page
                AddCorner(row)
                AddStroke(row, Theme.Border, 1)

                local lbl = Instance.new("TextLabel")
                lbl.Size              = UDim2.new(1, -100, 1, 0)
                lbl.Position          = UDim2.fromOffset(12, 0)
                lbl.BackgroundTransparency = 1
                lbl.Text              = label
                lbl.TextColor3        = Theme.Text
                lbl.TextSize          = 13
                lbl.Font              = Enum.Font.Gotham
                lbl.TextXAlignment    = Enum.TextXAlignment.Left
                lbl.Parent            = row

                local keyBtn = Instance.new("TextButton")
                keyBtn.Size              = UDim2.fromOffset(72, 24)
                keyBtn.Position          = UDim2.new(1, -82, 0.5, -12)
                keyBtn.BackgroundColor3  = Color3.fromRGB(30, 30, 44)
                keyBtn.Text              = key.Name
                keyBtn.TextColor3        = Theme.Accent
                keyBtn.TextSize          = 11
                keyBtn.Font              = Enum.Font.GothamBold
                keyBtn.BorderSizePixel   = 0
                keyBtn.Parent            = row
                AddCorner(keyBtn, UDim.new(0, 5))

                keyBtn.MouseButton1Click:Connect(function()
                    binding = true
                    keyBtn.Text       = "..."
                    keyBtn.TextColor3 = Theme.TextDim
                end)

                UserInputService.InputBegan:Connect(function(input, gpe)
                    if binding and input.UserInputType == Enum.UserInputType.Keyboard then
                        binding        = false
                        key            = input.KeyCode
                        keyBtn.Text    = key.Name
                        keyBtn.TextColor3 = Theme.Accent
                    end
                    if not binding and input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode == key and not gpe then
                            if callback then task.spawn(callback) end
                        end
                    end
                end)

                return keyBtn
            end

            return Section
        end

        return Tab
    end

    -- ── _SelectTab ──────────────────────
    function Window:_SelectTab(tab)
        for _, t in ipairs(self._tabs) do
            t._page.Visible = false
            Tween(t._btn, {
                BackgroundColor3 = Color3.fromRGB(30, 30, 44),
                TextColor3       = Theme.TextDim,
            })
        end
        tab._page.Visible = true
        Tween(tab._btn, {
            BackgroundColor3 = Theme.Accent,
            TextColor3       = Theme.Text,
        })
        self._activeTab = tab
    end

    -- ── Notification ────────────────────
    function Window:Notify(title, message, duration)
        duration = duration or 3

        local notif = Instance.new("Frame")
        notif.Size              = UDim2.fromOffset(260, 60)
        notif.Position          = UDim2.new(1, -270, 1, 10)
        notif.BackgroundColor3  = Theme.Surface
        notif.BorderSizePixel   = 0
        notif.Parent            = gui
        AddCorner(notif)
        AddStroke(notif, Theme.Accent, 1)

        local accent = Instance.new("Frame")
        accent.Size              = UDim2.fromOffset(3, 40)
        accent.Position          = UDim2.fromOffset(8, 10)
        accent.BackgroundColor3  = Theme.Accent
        accent.BorderSizePixel   = 0
        accent.Parent            = notif
        AddCorner(accent, UDim.new(0, 2))

        local t = Instance.new("TextLabel")
        t.Size              = UDim2.new(1, -24, 0, 20)
        t.Position          = UDim2.fromOffset(18, 8)
        t.BackgroundTransparency = 1
        t.Text              = title
        t.TextColor3        = Theme.Text
        t.TextSize          = 13
        t.Font              = Enum.Font.GothamBold
        t.TextXAlignment    = Enum.TextXAlignment.Left
        t.Parent            = notif

        local m = Instance.new("TextLabel")
        m.Size              = UDim2.new(1, -24, 0, 16)
        m.Position          = UDim2.fromOffset(18, 30)
        m.BackgroundTransparency = 1
        m.Text              = message
        m.TextColor3        = Theme.TextDim
        m.TextSize          = 11
        m.Font              = Enum.Font.Gotham
        m.TextXAlignment    = Enum.TextXAlignment.Left
        m.Parent            = notif

        -- Slide in
        Tween(notif, {Position = UDim2.new(1, -270, 1, -70)}, 0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

        task.delay(duration, function()
            Tween(notif, {Position = UDim2.new(1, -270, 1, 10), BackgroundTransparency = 1}, 0.2)
            task.delay(0.25, function() notif:Destroy() end)
        end)
    end

    return Window
end

return ApexUI
