local function fighterSnapshot()
	local snap = {}
	for id, data in pairs((Main.Data and Main.Data.Fighters) or {}) do
		snap[tostring(id)] = fighterDisplay(id, data)
	end
	return snap
end

local function resetWebhook()
	webhookState.lastItems = itemSnapshot()
	webhookState.lastFighters = fighterSnapshot()
	webhookState.initialized = true
end
resetWebhook()

local function collectChanges()
	local items = itemSnapshot()
	local fighters = fighterSnapshot()
	local newItems, newFighters = {}, {}
	for name, amount in pairs(items) do
		local old = webhookState.lastItems[name] or 0
		if amount > old then table.insert(newItems, name .. " +" .. tostring(amount - old) .. " (total " .. amount .. ")") end
	end
	for id, name in pairs(fighters) do
		if not webhookState.lastFighters[id] then table.insert(newFighters, name .. " `" .. id .. "`") end
	end
	webhookState.lastItems = items
	webhookState.lastFighters = fighters
	return newItems, newFighters
end

local function trimField(text)
	text = tostring(text or "")
	if #text > 1000 then
		return string.sub(text, 1, 997) .. "..."
	end
	return text
end

local function makeEmbed(title, description, fields, color)
	return {
		title = title,
		description = description,
		color = color or 0xF4DA23,
		fields = fields or {},
		footer = {text = "GB Hub | " .. player.Name},
		timestamp = DateTime.now():ToIsoDate(),
	}
end

local function sendWebhookEmbed(embed)
	local req = requestFn()
	if webhookState.url == "" then webhookStatus:SetDesc("Coloque a URL do webhook."); return end
	if not req then webhookStatus:SetDesc("Executor sem request/http_request."); return end
	local ok = pcall(function()
		req({
			Url = webhookState.url,
			Method = "POST",
			Headers = {["Content-Type"] = "application/json"},
			Body = HttpService:JSONEncode({
				username = "GB Hub",
				embeds = {embed}
			})
		})
	end)
	webhookStatus:SetDesc(ok and "Webhook enviado." or "Erro ao enviar webhook.")
end

