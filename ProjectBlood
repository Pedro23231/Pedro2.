local function traitValues()
	local values = {"Any Legendary+", "Any Mythical+", "Any Secret"}
	local filter = string.lower(traitState.filter or "")
	for name, data in pairs(Main.Shared.Traits or {}) do
		local label = tostring(name) .. " [" .. tostring(data and data.Rarity or "?") .. "]"
		if filter == "" or string.find(string.lower(label), filter, 1, true) then
			table.insert(values, tostring(name))
		end
	end
	table.sort(values, function(a, b)
		local aa, bb = string.sub(a, 1, 3) == "Any", string.sub(b, 1, 3) == "Any"
		if aa ~= bb then return aa end
		return a < b
	end)
	return values
end

local TraitTarget = Tabs.Trait:AddDropdown("GBTraitTarget", {Title = "Trait alvo", Values = traitValues(), Multi = false, Default = "Any Mythical+"})
TraitTarget:OnChanged(function(v)
	if v == "Nada encontrado" then return end
	traitState.selectedTarget = v
end)
Tabs.Trait:AddInput("GBTraitFilter", {
	Title = "Filtrar trait",
	Default = "",
	Placeholder = "nome ou raridade",
	Finished = false,
	Callback = function(v)
		traitState.filter = v or ""
		TraitTarget:SetValues(traitValues())
	end
})

local function traitMatches(trait)
	local target = traitState.selectedTarget
	local data = Main.Shared.Traits and Main.Shared.Traits[trait or ""]
	local rarity = data and data.Rarity
	local value = rarityValue[rarity] or 0
	if target == "Any Legendary+" then return value >= rarityValue.Legendary end
	if target == "Any Mythical+" then return value >= rarityValue.Mythical end
	if target == "Any Secret" then return value >= rarityValue.Secret end
	return trait == target
end

local function setTraitStatus(text) traitStatus:SetDesc(text) end
local function runTrait()
	if traitState.running then return end
	if not TraitRemote then setTraitStatus("Remote Trait nao encontrado."); return end
	local fighter = getSelectedFighter(traitState.selectedFighter)
	if not fighter then setTraitStatus("Selecione um fighter primeiro."); return end
	if traitMatches(fighter.Trait) then setTraitStatus("Ja esta na trait alvo."); return end
	if itemCount("TraitReroll") <= 0 then setTraitStatus("Sem Trait Reroll."); return end

	traitState.running = true
	local rolls = 0
	while traitState.running do
		fighter = getSelectedFighter(traitState.selectedFighter)
		if not fighter then setTraitStatus("Fighter nao encontrado."); break end
		if traitMatches(fighter.Trait) then setTraitStatus("Meta batida: " .. tostring(fighter.Trait)); break end
		if itemCount("TraitReroll") <= 0 then setTraitStatus("Parou: sem Trait Reroll."); break end
		local ok, result = pcall(function()
			return TraitRemote:InvokeServer(traitState.selectedFighter)
		end)
		rolls = rolls + 1
		if not ok then setTraitStatus("Erro no remote Trait: " .. tostring(result)); break end
		setTraitStatus("Girando: " .. rolls .. " | atual " .. tostring(result or fighter.Trait or "Nenhuma") .. " | Skipando nao selecionadas")
		task.wait(0.2)
	end
	traitState.running = false
end

Tabs.Trait:AddButton({Title = "Iniciar trait", Callback = function() task.spawn(runTrait) end})
Tabs.Trait:AddButton({Title = "Parar trait", Callback = function() traitState.running = false; setTraitStatus("Trait parado.") end})
