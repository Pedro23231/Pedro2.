local function itemCount(name)
	local inv = Main.Data and Main.Data.Inventory
	local items = inv and inv.Items
	return tonumber(items and items[name]) or 0
end

local function fighterDisplay(id, data)
	local shared = data and Main.Shared.Fighters and Main.Shared.Fighters[data.Name]
	local name = (data and data.Custom_Name) or (shared and shared.Name) or (data and data.Name) or tostring(id)
	local rarity = shared and shared.Rarity
	if data and data.Shiny then name = "Shiny " .. name end
	if data and tonumber(data.Star) == 2 then name = name .. " 2S" end
	if data and data.Trait and data.Trait ~= "" then name = name .. " | " .. tostring(data.Trait) end
	if rarity then name = name .. " [" .. tostring(rarity) .. "]" end
	return name
end

local function passesSearch(text, search)
	search = string.lower(tostring(search or ""))
	if search == "" then return true end
	return string.find(string.lower(tostring(text or "")), search, 1, true) ~= nil
end

local function getFighterValues(search)
	local values = {}
	for id, data in pairs((Main.Data and Main.Data.Fighters) or {}) do
		local label = fighterDisplay(id, data) .. " | " .. tostring(id)
		if passesSearch(label, search) then
			table.insert(values, label)
		end
	end
	table.sort(values)
	if #values == 0 then
		table.insert(values, "Nada encontrado")
	end
	return values
end

local function idFromLabel(label)
	return tostring(label or ""):match("|%s*([^|]+)$") or tostring(label or "")
end

local function rankMeets(current, target)
	return (rankOrder[current or "E"] or 1) >= (rankOrder[target or "E"] or 1)
end

local function getSelectedFighter(id)
	return Main.Data and Main.Data.Fighters and Main.Data.Fighters[id]
end

local function openFrame(name)
	local target = frames and frames:FindFirstChild(name)
	local frameUtil = Main.Utils and Main.Utils.Frame
	if target and frameUtil then
		local frameObj = frameUtil:Get(target)
		if frameObj then
			frameObj:Active()
			return true
		end
	end
	return false
end

-- Trial Shop
local shopState = {selectedSlot = "", buying = false, amount = 1, search = "", items = {}}
local shopStatus = Tabs.Shop:AddParagraph({Title = "Status", Content = "Pronto."})

local function trialItemName(data, fallback)
	if data and data.Type == "Item" and Main.Shared.Items[data.Name] then
		return Main.Shared.Items[data.Name].Name or data.Name
	end
	return data and data.Name or fallback
end

local function refreshShop()
	table.clear(shopState.items)
	for slot, data in pairs(Main.Shared.TrialMerchant or {}) do
		table.insert(shopState.items, {
			slot = slot,
			label = trialItemName(data, slot) .. " | slot " .. tostring(slot),
			price = tonumber(data.Price) or 0,
			stock = tonumber(data.Stock) or 0
		})
	end
	table.sort(shopState.items, function(a, b) return tostring(a.slot) < tostring(b.slot) end)
	if shopState.selectedSlot == "" and shopState.items[1] then shopState.selectedSlot = shopState.items[1].slot end
end

local function shopValues()
	refreshShop()
	local values = {}
	for _, item in ipairs(shopState.items) do
		if passesSearch(item.label, shopState.search) then
			table.insert(values, item.label)
		end
	end
	if #values == 0 then table.insert(values, "Nada encontrado") end
	return values
end

local function selectedShopItem()
	for _, item in ipairs(shopState.items) do
		if tostring(item.slot) == tostring(shopState.selectedSlot) then return item end
	end
end

local function shopRemaining(item)
	local bought = Main.Data and Main.Data.TrialMerchant and Main.Data.TrialMerchant.List
	return math.max((item and item.stock or 0) - (tonumber(bought and bought[item.slot]) or 0), 0)
end

local function shopMax(item)
	if not item or item.price <= 0 then return 0 end
	return math.min(shopRemaining(item), math.floor(itemCount("TrialShard") / item.price))
end

local ShopDropdown = Tabs.Shop:AddDropdown("GBShopItem", {
	Title = "Item",
	Values = shopValues(),
	Multi = false,
	Default = 1
})
ShopDropdown:OnChanged(function(value)
	if value == "Nada encontrado" then return end
	shopState.selectedSlot = tostring(value):match("slot%s*(.+)$") or shopState.selectedSlot
end)

Tabs.Shop:AddInput("GBShopSearch", {
