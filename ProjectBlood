local function updateShopStatus(text)
	shopStatus:SetDesc(text)
end

local function buyAmount(amount)
	local item = selectedShopItem()
	if not item then updateShopStatus("Selecione um item."); return end
	local total = math.min(amount or shopState.amount or 1, shopMax(item))
	if total <= 0 then updateShopStatus("Sem estoque ou shards insuficientes."); return end

	shopState.buying = true
	for i = 1, total do
		if not shopState.buying then break end
		Main.Bridge:FireServer("General", "TrialMerchant", "Buy", item.slot)
		updateShopStatus("Comprando " .. item.label .. " " .. i .. "/" .. total)
		task.wait(BUY_DELAY)
	end
	shopState.buying = false
	updateShopStatus("Finalizado.")
end

