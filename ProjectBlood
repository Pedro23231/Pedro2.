-- Auto Sell Tower Shadow
local sellModes = {"Normal", "Shiny", "Star 2", "Normal + Shiny", "Normal + Star 2", "Shiny + Star 2", "Todos"}
local sellState = {enabled = false, mode = "Normal", modeSearch = "", baseline = {}, processed = {}, sold = 0}
local sellStatus = Tabs.Sell:AddParagraph({Title = "Status", Content = "Desligado. So vende Shadows novos dropados depois de ativar."})

local function setSellBaseline()
	table.clear(sellState.baseline)
	table.clear(sellState.processed)
	for id in pairs((Main.Data and Main.Data.Fighters) or {}) do sellState.baseline[id] = true end
end
setSellBaseline()

local function shouldSell(data)
	if not data or data.Name ~= "Shadow" then return false end
	local shiny = data.Shiny == true
	local star2 = tonumber(data.Star) == 2
	local normal = not shiny and not star2
	local mode = sellState.mode
	if mode == "Todos" then return true end
	if mode == "Normal" then return normal end
	if mode == "Shiny" then return shiny end
	if mode == "Star 2" then return star2 end
	if mode == "Normal + Shiny" then return normal or shiny end
	if mode == "Normal + Star 2" then return normal or star2 end
	if mode == "Shiny + Star 2" then return shiny or star2 end
	return false
end

local function sellModeValues()
	local values = {}
	for _, mode in ipairs(sellModes) do
		if passesSearch(mode, sellState.modeSearch) then
			table.insert(values, mode)
		end
	end
	if #values == 0 then table.insert(values, "Nada encontrado") end
	return values
end

local SellMode = Tabs.Sell:AddDropdown("GBSellMode", {Title = "Vender Shadow", Values = sellModeValues(), Multi = false, Default = "Normal"})
SellMode:OnChanged(function(v)
	if v == "Nada encontrado" then return end
	sellState.mode = v
	sellStatus:SetDesc("Filtro: " .. tostring(v))
end)

Tabs.Sell:AddInput("GBSellModeSearch", {
	Title = "Pesquisar filtro",
	Default = "",
	Placeholder = "normal, shiny, star...",
	Finished = false,
	Callback = function(value)
		sellState.modeSearch = value or ""
		SellMode:SetValues(sellModeValues())
	end
})

local SellToggle = Tabs.Sell:AddToggle("GBSellToggle", {Title = "Auto sell Shadow novos", Default = false})
SellToggle:OnChanged(function()
	sellState.enabled = Options.GBSellToggle.Value
	if sellState.enabled then
		setSellBaseline()
		sellStatus:SetDesc("Ligado. Aguardando Shadow novo. Filtro: " .. sellState.mode)
	else
		sellStatus:SetDesc("Desligado. Vendidos: " .. sellState.sold)
	end
end)
Tabs.Sell:AddButton({Title = "Reset baseline", Callback = function() setSellBaseline(); sellStatus:SetDesc("Baseline resetada. So drops novos daqui pra frente.") end})

task.spawn(function()
	while task.wait(0.55) do
		if sellState.enabled then
			for id, data in pairs((Main.Data and Main.Data.Fighters) or {}) do
				if not sellState.baseline[id] and not sellState.processed[id] then
					if shouldSell(data) then
						if Main.Data.Fighters_Equipped and Main.Data.Fighters_Equipped[id] then
							sellState.processed[id] = true
							sellStatus:SetDesc("Pulou equipado: " .. fighterDisplay(id, data))
						else
							if data.Locked then
								Main.Bridge:FireServer("Fighters", "Inventory", "Lock", id)
								task.wait(0.12)
							end
							Main.Bridge:FireServer("Fighters", "Inventory", "Dismantle", {id})
							sellState.processed[id] = true
							sellState.sold = sellState.sold + 1
							sellStatus:SetDesc("Vendido: " .. fighterDisplay(id, data) .. " | total " .. sellState.sold)
							task.wait(0.18)
						end
					elseif data and data.Name == "Shadow" then
						sellState.processed[id] = true
					end
				end
			end
		end
	end
end)

