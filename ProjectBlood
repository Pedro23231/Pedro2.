for _, stat in ipairs(statNames) do
	local dd = Tabs.Stats:AddDropdown("GBStats" .. stat, {Title = stat .. " minimo", Values = rankList, Multi = false, Default = "A"})
	dd:OnChanged(function(v) statsState.targets[stat] = v end)
end

local function allStatsMet(fighter)
	local stats = fighter and fighter.Stats or {}
	for _, stat in ipairs(statNames) do
		if not rankMeets(stats[stat], statsState.targets[stat]) then return false end
	end
	return true
end

local function statLocks(fighter)
	local locks = {}
	local stats = fighter and fighter.Stats or {}
	for _, stat in ipairs(statNames) do
		if rankMeets(stats[stat], statsState.targets[stat]) then locks[stat] = true end
	end
	return locks
end

local function setStatsStatus(text) statsStatus:SetDesc(text) end
local function runStats()
	if statsState.running then return end
	local fighter = getSelectedFighter(statsState.selectedFighter)
	if not fighter then setStatsStatus("Selecione um fighter primeiro."); return end
	if allStatsMet(fighter) then setStatsStatus("Ja bateu todas as metas."); return end
	if itemCount("StatsReroll") <= 0 then setStatsStatus("Sem Stats Reroll."); return end

	statsState.running = true
	local rolls = 0
	while statsState.running do
		fighter = getSelectedFighter(statsState.selectedFighter)
		if not fighter then setStatsStatus("Fighter nao encontrado."); break end
		if allStatsMet(fighter) then setStatsStatus("Meta batida. Parou."); break end
		if itemCount("StatsReroll") <= 0 then setStatsStatus("Parou: sem Stats Reroll."); break end
		Main.Bridge:FireServer("General", "Stats", "Reroll", statsState.selectedFighter, statLocks(fighter))
		rolls = rolls + 1
		local st = fighter.Stats or {}
		setStatsStatus("Girando: " .. rolls .. " | D " .. tostring(st.Damage or "-") .. " | Spd " .. tostring(st.SpeedAttack or "-") .. " | Ult " .. tostring(st.UltimateDamage or "-") .. " | Skipando nao selecionados")
		task.wait(0.22)
	end
	statsState.running = false
end

Tabs.Stats:AddButton({Title = "Iniciar stats", Callback = function() task.spawn(runStats) end})
Tabs.Stats:AddButton({Title = "Parar stats", Callback = function() statsState.running = false; setStatsStatus("Stats parado.") end})
