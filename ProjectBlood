task.spawn(function()
	while task.wait(1) do
		if webhookState.enabled then
			local waited = 0
			while webhookState.enabled and waited < webhookState.interval do
				task.wait(1)
				waited = waited + 1
			end
			if webhookState.enabled then
				local newItems, newFighters = collectChanges()
				if #newItems > 0 or #newFighters > 0 then
					local fields = {
						{name = "Player", value = "`" .. player.Name .. "`", inline = true},
						{name = "Intervalo", value = tostring(webhookState.interval) .. "s", inline = true},
					}
					if #newItems > 0 then
						table.insert(fields, {
							name = "Novos itens",
							value = trimField("- " .. table.concat(newItems, "\n- ")),
							inline = false,
						})
					end
					if #newFighters > 0 then
						table.insert(fields, {
							name = "Novos fighters",
							value = trimField("- " .. table.concat(newFighters, "\n- ")),
							inline = false,
						})
					end
					sendWebhookEmbed(makeEmbed(
						"Inventario atualizado",
						"Novos drops detectados pelo monitor do GB Hub.",
						fields,
						0xF4DA23
					))
				else
					webhookStatus:SetDesc("Check feito: nada novo.")
				end
			end
		end
	end
end)

